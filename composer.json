{
    "name": "dominasys/pagbank-php-sdk",
    "description": "SDK PHP da DominaSys para integrar com a API do PagBank.",
    "keywords": [
        "dominasys",
        "pagbank",
        "sdk",
        "php",
        "api"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Mangilli",
            "email": "nobrudevz@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-arch": "^4.0",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "Dominasys\\PagBank\\": "src/"
        }
    },
    "scripts": {
        "refactor": "rector process",
        "test": "pest --no-coverage",
        "test:coverage": "pest --coverage",
        "check": [
            "@refactor",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
